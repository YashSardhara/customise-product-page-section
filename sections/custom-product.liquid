{% comment %}
  Custom Product section — block based.
  Custom blocks: cp-title, cp-price, cp-variant (built from scratch).
  Reused theme block: buy-buttons (quantity + add-to-cart + accelerated checkout),
  so add-to-cart keeps the theme's fly-to-cart animation + cart drawer.
  cp-variant.js coordinates variant -> id input / price / media / availability.
{% endcomment %}

{% liquid
  assign s = section.settings
  assign product = product | default: closest.product
  if request.visual_preview_mode and product == blank
    assign product = collections.all.products.first
  endif
%}

<div class="cp" data-media-position="{{ s.media_position }}" {{ section.shopify_attributes }}>
  {% if product == blank %}
    <p class="cp__placeholder">Add this section to a product template to preview it.</p>
  {% else %}
    <div class="cp__grid">
      <cp-gallery class="cp__media">
        <div class="cp__media-frame">
          {% if product.featured_media %}
            <img
              class="cp__media-main"
              data-cp-media
              src="{{ product.featured_media.preview_image | image_url: width: 900 }}"
              width="{{ product.featured_media.preview_image.width }}"
              height="{{ product.featured_media.preview_image.height }}"
              alt="{{ product.featured_media.preview_image.alt | escape | default: product.title | escape }}"
              loading="eager"
            >
          {% else %}
            {{ 'product-1' | placeholder_svg_tag: 'cp__media-main' }}
          {% endif %}

          {% if product.images.size > 1 %}
            <button type="button" class="cp__nav cp__nav--prev" data-cp-prev aria-label="Previous image">&lsaquo;</button>
            <button type="button" class="cp__nav cp__nav--next" data-cp-next aria-label="Next image">&rsaquo;</button>
          {% endif %}
        </div>

        {% if s.show_thumbnails and product.images.size > 1 %}
          <div class="cp__thumbs">
            {% for image in product.images %}
              <button
                type="button"
                class="cp__thumb{% if forloop.first %} is-active{% endif %}"
                data-cp-thumb
                data-cp-thumb-src="{{ image | image_url: width: 900 }}"
                aria-label="Image {{ forloop.index }}"
              >
                <img src="{{ image | image_url: width: 120 }}" width="60" height="60" loading="lazy" alt="">
              </button>
            {% endfor %}
          </div>
        {% endif %}

        {% if product.images.size > 1 %}
          <script type="application/json" data-cp-images>
            [{% for image in product.images %}{{ image | image_url: width: 900 | json }}{% unless forloop.last %},{% endunless %}{% endfor %}]
          </script>
        {% endif %}
      </cp-gallery>

      <div class="cp__info">
        {% content_for 'blocks' %}
      </div>
    </div>
  {% endif %}
</div>

<script src="{{ 'custom-product.js' | asset_url }}" defer></script>

{% stylesheet %}
  .cp {
    display: block;
    max-width: var(--page-width, 1200px);
    margin-inline: auto;
    padding: 2rem 1.25rem;
  }

  .cp__grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: 1fr;
  }

  @media screen and (min-width: 750px) {
    .cp__grid {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      align-items: start;
    }

    .cp[data-media-position="right"] .cp__media {
      order: 2;
    }

    .cp__info {
      position: sticky;
      top: calc(var(--header-height, 0px) + 1.5rem);
    }
  }

  .cp__media { display: block; }

  .cp__media-frame { position: relative; }

  .cp__media-main {
    width: 100%;
    height: auto;
    border-radius: var(--style-border-radius-inputs, 8px);
    object-fit: contain;
    background: var(--color-background-secondary, #f5f5f5);
  }

  .cp__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.85);
    color: #1a1a1a;
    font-size: 1.6rem;
    line-height: 1;
    cursor: pointer;
    box-shadow: 0 1px 6px rgba(0, 0, 0, 0.18);
  }

  .cp__nav:hover { background: #fff; }
  .cp__nav--prev { inset-inline-start: 0.5rem; }
  .cp__nav--next { inset-inline-end: 0.5rem; }

  .cp__thumbs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }

  .cp__thumb {
    padding: 0;
    border: 2px solid transparent;
    border-radius: 6px;
    background: none;
    cursor: pointer;
    line-height: 0;
    overflow: hidden;
  }

  .cp__thumb.is-active {
    border-color: var(--color-foreground, #1a1a1a);
  }

  .cp__thumb img {
    width: 60px;
    height: 60px;
    object-fit: cover;
  }

  .cp__info {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* Outline box around the reused theme quantity selector */
  .cp__info quantity-selector-component {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--color-foreground, #1a1a1a);
    border-radius: var(--style-border-radius-inputs, 6px);
    overflow: hidden;
  }

  .cp__placeholder {
    padding: 2rem;
    text-align: center;
    opacity: 0.7;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Custom product",
  "tag": "section",
  "class": "section-custom-product",
  "settings": [
    {
      "type": "select",
      "id": "media_position",
      "label": "Desktop media position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "checkbox",
      "id": "show_thumbnails",
      "label": "Show image thumbnails",
      "default": true
    }
  ],
  "blocks": [
    { "type": "cp-badge" },
    { "type": "cp-title" },
    { "type": "cp-price" },
    { "type": "cp-variant" },
    { "type": "buy-buttons" },
    { "type": "cp-description" },
    { "type": "cp-icon-row" },
    { "type": "cp-richtext" },
    { "type": "why-customers-love" },
    { "type": "@app" }
  ],
  "enabled_on": {
    "templates": ["product"]
  },
  "presets": [
    {
      "name": "Custom product",
      "blocks": [
        { "type": "cp-badge" },
        { "type": "cp-title" },
        { "type": "cp-price" },
        { "type": "cp-variant" },
        { "type": "buy-buttons" },
        { "type": "cp-description" },
        { "type": "why-customers-love" }
      ]
    }
  ]
}
{% endschema %}

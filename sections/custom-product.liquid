{% comment %}
  Custom Product section — block based.
  Custom blocks: cp-title, cp-price, cp-variant (built from scratch).
  Reused theme block: buy-buttons (quantity + add-to-cart + accelerated checkout),
  so add-to-cart keeps the theme's fly-to-cart animation + cart drawer.
  cp-variant.js coordinates variant -> id input / price / media / availability.
{% endcomment %}

{% liquid
  assign s = section.settings
  assign product = product | default: closest.product
  if request.visual_preview_mode and product == blank
    assign product = collections.all.products.first
  endif
%}

<div class="cp" data-media-position="{{ s.media_position }}" {{ section.shopify_attributes }}>
  {% if product == blank %}
    <p class="cp__placeholder">Add this section to a product template to preview it.</p>
  {% else %}
    <div class="cp__grid">
      <div class="cp__media">
        {% if product.featured_media %}
          <img
            class="cp__media-main"
            data-cp-media
            src="{{ product.featured_media.preview_image | image_url: width: 900 }}"
            srcset="
              {{ product.featured_media.preview_image | image_url: width: 500 }} 500w,
              {{ product.featured_media.preview_image | image_url: width: 900 }} 900w,
              {{ product.featured_media.preview_image | image_url: width: 1400 }} 1400w"
            sizes="(min-width: 750px) 45vw, 100vw"
            width="{{ product.featured_media.preview_image.width }}"
            height="{{ product.featured_media.preview_image.height }}"
            alt="{{ product.featured_media.preview_image.alt | escape | default: product.title | escape }}"
            loading="eager"
          >
        {% else %}
          {{ 'product-1' | placeholder_svg_tag: 'cp__media-main' }}
        {% endif %}

        {% if s.show_thumbnails and product.images.size > 1 %}
          <div class="cp__thumbs" data-cp-thumbs>
            {% for image in product.images limit: 6 %}
              <button
                type="button"
                class="cp__thumb{% if forloop.first %} is-active{% endif %}"
                data-cp-thumb
                data-cp-thumb-src="{{ image | image_url: width: 900 }}"
                aria-label="Image {{ forloop.index }}"
              >
                <img src="{{ image | image_url: width: 120 }}" width="60" height="60" loading="lazy" alt="">
              </button>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <div class="cp__info">
        {% content_for 'blocks' %}
      </div>
    </div>
  {% endif %}
</div>

<script src="{{ 'custom-product.js' | asset_url }}" defer></script>

{% stylesheet %}
  .cp {
    display: block;
    max-width: var(--page-width, 1200px);
    margin-inline: auto;
    padding: 2rem 1.25rem;
  }

  .cp__grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: 1fr;
  }

  @media screen and (min-width: 750px) {
    .cp__grid {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      align-items: start;
    }

    .cp[data-media-position="right"] .cp__media {
      order: 2;
    }

    .cp__info {
      position: sticky;
      top: calc(var(--header-height, 0px) + 1.5rem);
    }
  }

  .cp__media-main {
    width: 100%;
    height: auto;
    border-radius: var(--style-border-radius-inputs, 8px);
    object-fit: contain;
    background: var(--color-background-secondary, #f5f5f5);
  }

  .cp__thumbs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }

  .cp__thumb {
    padding: 0;
    border: 2px solid transparent;
    border-radius: 6px;
    background: none;
    cursor: pointer;
    line-height: 0;
    overflow: hidden;
  }

  .cp__thumb.is-active {
    border-color: var(--color-foreground, #1a1a1a);
  }

  .cp__thumb img {
    width: 60px;
    height: 60px;
    object-fit: cover;
  }

  .cp__info {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .cp__placeholder {
    padding: 2rem;
    text-align: center;
    opacity: 0.7;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Custom product",
  "tag": "section",
  "class": "section-custom-product",
  "settings": [
    {
      "type": "select",
      "id": "media_position",
      "label": "Desktop media position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "checkbox",
      "id": "show_thumbnails",
      "label": "Show image thumbnails",
      "default": true
    }
  ],
  "blocks": [
    { "type": "cp-title" },
    { "type": "cp-price" },
    { "type": "cp-variant" },
    { "type": "buy-buttons" },
    { "type": "why-customers-love" },
    { "type": "@app" }
  ],
  "enabled_on": {
    "templates": ["product"]
  },
  "presets": [
    {
      "name": "Custom product",
      "blocks": [
        { "type": "cp-title" },
        { "type": "cp-price" },
        { "type": "cp-variant" },
        { "type": "buy-buttons" },
        { "type": "why-customers-love" }
      ]
    }
  ]
}
{% endschema %}

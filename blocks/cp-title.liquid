{% comment %} Custom product title block. {% endcomment %}
{% liquid
  assign b = block.settings
  assign product = closest.product
  if request.visual_preview_mode and product == blank
    assign product = collections.all.products.first
  endif
%}

{% capture title_html %}{{ product.title | escape | default: 'Product title' }}{% endcapture %}

<div
  class="cp-title cp-title--{{ b.alignment }}"
  style="--cp-title-size: {{ b.font_size }}px;"
  {{ block.shopify_attributes }}
>
  {% case b.heading_tag %}
    {% when 'h1' %}<h1 class="cp-title__text">{{ title_html }}</h1>
    {% when 'h2' %}<h2 class="cp-title__text">{{ title_html }}</h2>
    {% else %}<h3 class="cp-title__text">{{ title_html }}</h3>
  {% endcase %}
</div>

{% stylesheet %}
  .cp-title__text {
    margin: 0;
    font-size: var(--cp-title-size, 28px);
    line-height: 1.15;
  }
  .cp-title--center { text-align: center; }
  .cp-title--right { text-align: right; }
{% endstylesheet %}

{% schema %}
{
  "name": "Product title",
  "tag": null,
  "settings": [
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ],
      "default": "h1"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 12,
      "max": 48,
      "step": 1,
      "unit": "px",
      "default": 28
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    }
  ],
  "presets": [{ "name": "Product title" }]
}
{% endschema %}

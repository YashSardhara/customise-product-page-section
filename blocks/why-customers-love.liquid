{% liquid
  assign block_settings = block.settings
%}

<div
  class="why-love spacing-style"
  style="{% render 'spacing-style', settings: block_settings %} --why-love-accent: {{ block_settings.accent_color }};"
  {{ block.shopify_attributes }}
>
  <div class="why-love__card">
    {% if block_settings.heading != blank %}
      <h2 class="why-love__title">{{ block_settings.heading | escape }}</h2>
    {% endif %}

    <ul class="why-love__list">
      {% for i in (1..3) %}
        {% assign bullet_key = 'bullet_' | append: i %}
        {% assign bullet = block_settings[bullet_key] %}
        {% if bullet != blank %}
          <li class="why-love__item">{{ bullet | escape }}</li>
        {% endif %}
      {% endfor %}
    </ul>
  </div>
</div>

{% stylesheet %}
  .why-love__card {
    padding: 1.25rem 1.5rem;
    background: var(--color-background, #fff);
    border: 1px solid var(--color-border, #e8e8e8);
    border-radius: var(--style-border-radius-popover, 12px);
    box-shadow: var(--shadow-popover, 0 4px 16px rgba(0, 0, 0, 0.08));
  }

  .why-love__title {
    font-size: var(--font-size--lg, 1.15rem);
    margin: 0 0 0.75rem;
  }

  .why-love__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .why-love__item {
    position: relative;
    padding-inline-start: 1.75rem;
    line-height: 1.4;
  }

  .why-love__item::before {
    content: "";
    position: absolute;
    inset-inline-start: 0.4rem;
    top: 0.55em;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: var(--why-love-accent, var(--color-foreground));
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Why customers love this",
  "tag": "Product-page-block",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why Customers Love This Product"
    },
    {
      "type": "text",
      "id": "bullet_1",
      "label": "Bullet 1",
      "default": "Dermatologist-tested and safe for daily use"
    },
    {
      "type": "text",
      "id": "bullet_2",
      "label": "Bullet 2",
      "default": "Made with clean, cruelty-free ingredients"
    },
    {
      "type": "text",
      "id": "bullet_3",
      "label": "Bullet 3",
      "default": "Loved by 50,000+ happy customers"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Bullet accent color",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "Left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "Right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Why customers love this",
      "category": "Product"
    }
  ]
}
{% endschema %}

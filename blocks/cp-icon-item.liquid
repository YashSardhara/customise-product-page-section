{% comment %} Single icon + label. Child of cp-icon-row. {% endcomment %}
{% liquid assign b = block.settings %}

<div class="cp-icon-item" {{ block.shopify_attributes }}>
  {% if b.image != blank %}
    <img
      class="cp-icon-item__img"
      src="{{ b.image | image_url: width: 200 }}"
      width="{{ b.image.width }}"
      height="{{ b.image.height }}"
      loading="lazy"
      alt="{{ b.text | escape }}"
    >
  {% else %}
    <span class="cp-icon-item__img cp-icon-item__img--placeholder">
      {{ 'image' | placeholder_svg_tag: 'cp-icon-item__placeholder-svg' }}
    </span>
  {% endif %}

  {% if b.text != blank %}
    <span class="cp-icon-item__text">{{ b.text | escape }}</span>
  {% endif %}
</div>

{% stylesheet %}
  .cp-icon-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    text-align: center;
  }
  .cp-icon-item__img {
    width: var(--cp-icon-size, 48px);
    height: var(--cp-icon-size, 48px);
    object-fit: contain;
  }
  .cp-icon-item__placeholder-svg {
    width: 100%;
    height: 100%;
  }
  .cp-icon-item__text {
    font-size: 0.9rem;
    line-height: 1.3;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Icon item",
  "tag": null,
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Icon image" },
    { "type": "text", "id": "text", "label": "Text", "default": "Feature" }
  ],
  "presets": [{ "name": "Icon item" }]
}
{% endschema %}
